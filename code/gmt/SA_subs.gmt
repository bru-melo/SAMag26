}

function TRANSBRASILIANO(){
  opt=$1
  pen1=$2
  pen2=$3
  echo "    --Add Transbrasiliano"
  if [ $opt = "define" ]; then
    #gmt plot $contours/lineaments/TBLconfirmed.txt -W${pen1} -l"TBL"
    gmt plot $contours/lineaments/TBLconfirmed.txt -W${pen1}
  elif [ $opt = "proposed" ]; then
    gmt plot $contours/CPRM/lineaments/TBL.txt -W${pen2} -l"TBL Proposed"
  else
    #gmt plot $contours/lineaments/TBLconfirmed.txt -W${pen1} -l"TBL"
    gmt plot $contours/lineaments/TBLconfirmed.txt -W${pen1} 
    #gmt plot $contours/CPRM/lineaments/TBL.txt -W${pen2} -l"TBL Proposed"
    gmt plot $contours/CPRM/lineaments/TBL.txt -W${pen2} 
  fi
}

