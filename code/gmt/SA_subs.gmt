#!/usr/bin/env bash

#- brunas gmt file repo
contours="$REPO_ROOT/data/contours"
cpt_dir="$REPO_ROOT/code/gmt/cpt"
tomocpt="${cpt_dir}/bry-bp2_ELv5.cpt"
function PLOT_PLATES () {
  pen=$1

  bird="$REPO_ROOT/data/plate_boundaries/bird2003.txt"
  gmt plot -W${pen} ${bird}
}

function ARCHEAN() {
  pen=$1
  fill=$2
  add=$3
  echo "    --Add Archean"
  if [ $fill != "empty" ]; then 
    gmt plot $contours/cratons/archean_simple.txt -W$pen -G$fill $add
  else
    gmt plot $contours/cratons/archean_simple.txt  -W$pen $add
  fi
}

function PALEO() {
  pen=$1
  fill=$2
  add=$3
  echo "    --Add Paleoproterozoic"
  if [ $fill != "empty" ]; then
    gmt plot $contours/cratons/paleo_simple.txt -W$pen -G$fill $add
  else
    gmt plot $contours/cratons/paleo_simple.txt -W$pen $add
  fi
}

function MESO() {
  pen=$1
  fill=$2
  echo "    --Add Mesoproterozoic"
  if [ $fill != "empty" ]; then 
    gmt plot $contours/CPRM/cratons/Mesoproterozoic_SA.gmt -W$pen -G$fill
  else
    gmt plot $contours/CPRM/cratons/Mesoproterozoic_SA.gmt -W$pen
  fi
}

function NEO() {
  pen=$1
  fill=$2
  echo "    --Add Neoproterozoic"
  if [ $fill != "empty" ]; then 
    gmt plot $contours/CPRM/terraines/Neoproterozoic.txt -W$pen -G$fill -l"Neoproterozoic Belts"
  else
    gmt plot $contours/CPRM/terraines/Neoproterozoic.txt -W$pen -m -l"Neoproterozoic Belts"
  fi
}

function CENO() {
  pen=$1
  fill1=$2
  fill2=$3
  fill3=$4
  echo "    --Add Phanerozoic"
  if [ $pen != "empty" ]; then 
    gmt plot $contours/CPRM/terraines/Cenozoic_Inset.txt -W$pen -G$fill1 
    #gmt plot $contours/CPRM/terraines/early_paleo.csv -W$pen -G$fill2 -l"Early Paleozoic Terraines"
    #gmt plot $contours/CPRM/terraines/Patagonia_palo.csv -W$pen -G$fill3 -l"Late Paleozoic Terraines"
    #gmt plot $contours/CPRM/terraines/Mezo_Ceno.csv -W$pen -G$fill4 -l"Meso/Cenozoic Terraines"
  else
    gmt plot $contours/CPRM/terraines/Cenozoic_Inset.txt -G$fill1
    #gmt plot $contours/CPRM/terraines/early_paleo.csv -W$pen -l"Early Paleozoic Terraines"
    #gmt plot $contours/CPRM/terraines/Patagonia_palo.csv -W$pen  -l"Late Paleozoic Terraines"
    #gmt plot $contours/CPRM/terraines/Mezo_Ceno.csv -W$pen  -l"Meso/Cenozoic Terraines"
