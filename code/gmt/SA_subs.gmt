  pen=$1
  echo "    --Add SFC aulacogens"
  gmt plot $contours/lineaments/SFC_aulacogen.txt -W$pen -l"Rifts"
}

function MAG(){

  maxage=2500
  symbol=$1
  pen=$2
  fill=$3
  maxage=$4
  echo "    --Add magmatism"

  awk -F, -v ma=$maxage '($3<ma) && ($3!=0) {print $1,$2,$3}' $gmt_BM/data/Kimberlites/magmatism_all.csv | gmt plot -S$symbol -W$pen $fill
  if [ $maxage -le 66 ]; then
    awk -F, '(NR>1) {print $1,$2, 65}' $gmt_BM/data/Magmatism/Patagonia_Dorazioetal2004.csv | gmt plot -S$symbol -W$pen $fill -l"Cenozoic Magmatism"
    awk -F, '(NR>1) && ($5<66) {print $1,$2,$5}' $gmt_BM/data/Magmatism/updates.csv | gmt plot -S$symbol -W$pen $fill
    grep "CENOZOIC" $gmt_BM/data/Magmatism/Borborema_lat_lon.csv | awk -F, '(NR>1) {print $2, $1, 65}' | gmt plot -S$symbol -W$pen $fill 
  elif [ $maxage -ge 200 ]; then
    awk '{print $1,$2, 200}' $contours/magmatism/santos_2002/mesozoic.gmt | gmt plot -S$symbol -W$pen $fill
  fi
}

function KIM(){
  symbol=$1
  pen=$2
  fill=$3
  opt=$4
  echo "    --Add kimberlites"

  minage=2000
  case $opt in
    cluster)
      gmt plot $contours/magmatism/kimberlite_cluster.txt -W$pen -G$fill -l"Kimberlite Clusters"
      ;;
    data)
      #data without age
      awk -F, ' {print $1,$2}' $gmt_BM/data/Kimberlites/CPRM_projetodiamante/1_CorposKimberliticos_aplicacao.csv | gmt plot -S$symbol -W$pen $fill -l"All kimberlites"
      awk -F, '($26>0) {print $1,$2,$26}' $gmt_BM/data/Kimberlites/CPRM_projetodiamante/1_CorposKimberliticos_aplicacao.csv | gmt plot -S$symbol -W$pen $fill 
      ;;
  esac
}

function DIA(){
  symbol=$1
  pen=$2
  fill=$3
  echo "    --Add diamonds"
  
  #projeto diamante
  awk -F, '($19=="Sim")  && (NR>1) {print $1,$2}' $gmt_BM/data/Kimberlites/CPRM_projetodiamante/1_CorposKimberliticos_aplicacao.csv | gmt plot -S$symbol -W$pen -Gwhite
  awk -F, '($5=="DM") && ($15>0) {print $6,$7,$15}' $gmt_BM/data/Kimberlites/Consorem/world_kimberlites_and_lamproites_consorem_database_v2010.csv | gmt plot -S$symbol -W$pen $fill -l"Diamondiferous Kimberlites"
  awk -F, '($19=="Sim") && (NR>1) && ($26>0) {print $1,$2,$26}' $gmt_BM/data/Kimberlites/CPRM_projetodiamante/1_CorposKimberliticos_aplicacao.csv | gmt plot -S$symbol -W$pen $fill
  #paraguay
  #gmt plot $gmt_BM/data/Kimberlites/paraguay_diamond.txt -Sc0.15 -W$pen -Ggray -l"DK (unconfirmed)"
  #gmt plot $gmt_BM/data/Kimberlites/paraguay_diamond.txt -S$symbol -W$pen -G$fill -l"DMK (unconfirmed)"
}

function INTRAPLATE(){
  symbol=$1
  pen=$2
  fill=$3
  echo "    --Add intraplate seismicity"

  awk -F"|" '(NR>1) {print $4,$3}' $gmt_BM/data/seismicity/RSBR/catalogue | gmt gmtselect -Ns/k -F$gmt_BM/data/seismicity/RSBR/intraplate_selection.txt | gmt plot -S$symbol -G$fill -W$pen -l"Intraplate Seismicity"
}

function SEISMICITY(){
  ker=$1
  dep=$2
  symbol=$3
  pen=$4
  fill=$5

  echo "    --Add seismicity"

  catalogue=${gmt_BM}/data/seismicity/USGS/seis.yxz
  #gmt makecpt -T-50/700/10 -D -Crainbow -Z -I > seis.cpt.$tmp
  #awk -v a=$ker -v b=$dep '($3>40) && ($4>4) {if($3>=(b-a) && $3<=(b+a)) print $2,$1,$3,($4**3)*0.00002 }' ${catalogue} | gmt plot -Sc -W$pen -G$fill
  awk -v a=$ker -v b=$dep '($3>40) && ($4>4) {if($3>=(b-a) && $3<=(b+a)) print $2,$1,$3 }' ${catalogue} | gmt plot -S$symbol -W$pen -G$fill
}

function STRUCTURE(){
  pen=$1
  echo "    --Add continent structure"

  gmt plot $contours/CPRM/lineaments/Continent_Structure.txt -W$pen -l"Continental Structure"
}

function HOTSPOT(){
  symbol=$1
  pen=$2
  fill=$3
  echo "    --Add hotspots"
  gmt plot $gmt_BM/data/Hotspots_Compilation_Whittaker_etal.xy -S$symbol -W$pen -G$fill -l"Hotspots"
}

function PARANA(){
  pen1=$1
  pen2=$2
  echo "    --Add Parana"

  if [ ${pen2} == "skip" ]; then
    #echo "        --case 1: plot Cordani"
    grep "nucleo_cratonico" $contours/Parana/parana_zalan.txt | gmt plot -W$pen1 -L -l"Cordani (1980)"

  elif [ ${pen1} == "skip" ]; then
    #echo "        --case 2: plot Mantovani?"
    i=0
    for block in $contours/Parana/paranapanema.txt $contours/Parana/triangulo_mineiro.txt $contours/Parana/guaxupe.txt; do
      if [ $i == 0 ]; then 
        gmt plot $block -W${pen2} -l"Milani and Ramos (2008)"
      else
        gmt plot $block -W${pen2}
      fi
      ((i++))
    done

  else
    echo "        --case 3: plot both"
    grep "nucleo_cratonico" $contours/Parana/parana_zalan.txt | gmt plot -W${pen1} -L -l"Paraná Block (1)"
    i=0
    for block in $contours/Parana/paranapanema.txt $contours/Parana/triangulo_mineiro.txt $contours/Parana/guaxupe.txt; do
      if [ $i == 0 ]; then 
        gmt plot $block -W${pen2} -l"Paraná Block (2)"
      else
        gmt plot $block -W${pen2}
      fi
      ((i++))
    done
  fi
}

function LAB(){
  echo "    --Add LAB"
  awk '{print $3,$2,$4}' $REPO_ROOT/data/seismic_model/heit2007.txt | gmt plot -Sc0.1c -Gwhite -W0.1p
  awk '{print $3,$2,$4}' $REPO_ROOT/data/seismic_model/heit2007.txt | gmt text -F+f8p+jTL -D-0.15 -Gwhite -W0.1p
}

