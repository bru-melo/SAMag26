}

function ANDES() {
  pen=$1
  fill=$2
  echo "    --Add Andes"
  if [ $fill != "empty" ]; then 
    gmt plot $contours/CPRM/terraines/Andean_Belt_Inset.shp.txt -W$pen -G$fill -l"Andean Belt"
  else
    gmt plot $contours/CPRM/terraines/Andean_Belt_Inset.shp.txt -W$pen  -l"Andean Belt"
  fi
}

function CRATON() {
  pen=$1
  fill=$2
  echo "    --Add cratons"

  #-- Inferred Craton Limits
  i=0
  for craton in $contours/CPRM/cratons/Sao_Luiz_Craton2.txt $contours/cratons/outer_layer.txt $contours/cratons/SFC_bru.gmt $contours/CPRM/cratons/Luiz_Alves_Craton.txt  $contours/CPRM/cratons/Sao_Luiz_Craton.txt $contours/CPRM/cratons/Sao_Luiz_Craton2.txt; do
    # $contours/cratons/Guyana_Rizzotto.txt $contours/cratons/Guapore_Rizzotto.txt; do
    if [ $fill == "empty" ]; then 
      if [ $i == 0 ]; then 
      gmt plot $craton -W${pen}  -l"Main Cratons"
      else
      gmt plot $craton -W${pen}
      fi
    else
      if [ $i == 0 ]; then 
        gmt plot $craton -W${pen} -G$fill 
      else
        gmt plot $craton -W${pen} -G$fill
      fi
    fi
    ((i++))
  done
}

function INFCRATON() {
  pen=$1
  fill=$2
  echo "    --Add inferred cratons"

  #-- Inferred Craton Limits
  i=0
  for craton in $contours/CPRM/cratons/Parnaiba_block.txt $contours/CPRM/cratons/Paranapanema.txt $contours/CPRM/cratons/Rio_de_la_Plata_Craton.txt; do
    # $contours/cratons/Guyana_Rizzotto.txt $contours/cratons/Guapore_Rizzotto.txt; do
    if [ $fill != "empty" ]; then 
      if [ $i == 0 ]; then 
      gmt plot $craton -W${pen} -G$fill -l"Proposed Cratons"
      else
      gmt plot $craton -W${pen} -G$fill
      fi
    else
      if [ $i == 0 ]; then 
        gmt plot $craton -W${pen} -l"Proposed Cratons" 
      else
        gmt plot $craton -W${pen}
      fi
    fi
    ((i++))
  done
}

function AMAZON_PROVINCES(){
  pen=$1
  #opt=$2
  clr="pink pink magenta orange green darkblue yellow red"
  colors=(${clr})
  province=$(ls $contours/cratons/vasques_rosacosta2008/*.gmt)
  dir=$contours/cratons/vasques_rosacosta2008/
  pro=(${province})
  len=${#pro[@]}

  echo "    --Add Amazon Provinces"
 
  #echo "colors: $colors; clr: $clr" 
  for ((i=0;i<${len};++i)); do
    if [ $i == 0 ];then
      #gmt plot ${pro[$i]} -W${pen} -G${colors[$i]}@60 -l"Amazon Provinces"
      gmt plot ${pro[$i]} -W${pen} -l"Amazon Provinces"
    else
      #gmt plot ${pro[$i]} -W${pen} -G${colors[$i]}@60
      gmt plot ${pro[$i]} -W${pen}
    fi
  done
}

function BASIN() {
  pen=$1
  fill=$2
  echo "    --Add Basins"
  if [ $fill != "empty" ]; then 
    gmt plot $contours/basins/contorno_cpb-pb.txt -L -W$pen -G$fill -l"Sedimentary Basins"
    gmt plot $contours/basins/Paranaiba.kml.xy -W$pen  -G$fill
    gmt plot $contours/basins/pantanal.xy -W$pen -G$fill
    gmt plot $contours/basins/parecis -W$pen -G$fill
    gmt plot $contours/basins/amazon_basin.txt -W$pen -G$fill 
    gmt plot $contours/basins/araguaia_basin.txt -W$pen -G$fill
    gmt plot $contours/basins/urucuia_basin.txt -W$pen -G$fill
  else
    gmt plot $contours/basins/contorno_cpb-pb.txt -L -W$pen -l"Sedimentary Basins"
    gmt plot $contours/basins/Paranaiba.kml.xy -W$pen
    gmt plot $contours/basins/pantanal.xy -W$pen
    gmt plot $contours/basins/parecis -W$pen
  fi
}
function AM_GRAV_HIGH(){
  pen=$1
  echo "    --Add Amazon Gravity High"
  gmt plot $contours/cratons/amazon_grav_high3.txt -W$pen -l"Gravity High*"
}

function SUTURE_ZONE() {
  pen1=$1
  pen2=$2
  echo "    --Add Suture Zones"
