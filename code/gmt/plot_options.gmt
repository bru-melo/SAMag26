function LABEL(){
  awk '{print $1,$2,$3}' $contour_dir/lip_ages.txt | gmt text -F+f6p,AvantGarde-Demi,black -Gwhite
  awk '{print $1,$2,$3}' $folder/hotspots/hotspot_catalogue.xy | gmt text -F+f8p,Helvetica-Bold,white
  awk '{print $1,$2,$3}' $contour_dir/lip_names.txt | gmt text -F+f8p,Helvetica-Bold
}
#------------------------------------------------------------------------------------------#
function FLOWTHICK(){
  echo $tag"~~overlay LIPs lava flow thickness"
  i=0
  for lip in camp_outline.txt serra_geral_outline.txt \
    somuncura_kay2007.txt triple_junction_kay2007.txt \
    payenia_kay2007.txt pali_aike_kay2007.txt \
    canquel_kay2007.txt; do
        if [ $i == 0 ]; then
          gmt plot $contour_dir/$lip -W2p,red -l"LIPs"
        else
          gmt plot $contour_dir/$lip -W2p,red
        fi
        ((i++))
  done
  gmt contour $folder/flood_basalts/parana_contour_zalan1987.txt -W1p,red -C"501,900,1300,1500" -A"900,1500," -l"Basalt Thickness"
  gmt contour $folder/flood_basalts/camp_demin_all.txt -W1p,red -C"301,500,700" -A"500,700,"
}
