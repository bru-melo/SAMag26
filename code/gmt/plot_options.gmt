function SEIS(){
  dep=$1
  #mndep=$1
  #mxdep=$2
  echo "  plot seismicity"
  seis_dir="${gmt_BM}/data/seismicity/USGS/seis.yxz"; ker=10
  scpt=$(gmt makecpt -T-50/700/10 -D -Crainbow -Z -I)
  #scpt=$(gmt makecpt -T$mndep/$mxdep/50 -Crainbow -Z -I)
  #gmt makecpt -T-50/700/10 -D -Crainbow -Z -I
  awk -v a=$ker -v b=$dep '($3>100) && ($4>5) {if($3>=(b-a) && $3<=(b+a)) print $2,$1,$3,($4**3)*0.0005 }' ${seis_dir} | gmt plot -Sc -W0.25p,black -C$scpt
  #awk '($3>70) && ($4>5) {print $2,$1,$3,($4**3)*0.0003 }' ${seis_dir} | gmt plot -Sc -W0.1p,black -C$scpt
}

function LIP(){
  liprovince=$1
  echo $tag"~~overlay LIPs and Oceanic Plateaus"
  gmt gmtselect $contour_dir/oceanic_features.gmt -R"-70/-5/-56/13.5" | gmt plot $R -W0.5p,red -GP300/7:Bred27F- -l"Seamounts"
  case ${liprovince} in
    fill) atrb="-GP300/7:Bgray27F- -W1p";;
    #fill) atrb="-Gsienna -W0.5p,sienna";;
    line) atrb="-W2p"; atrb2="-W0.8p,white";;
  esac
  i=0
  for lip in camp_outline.txt serra_geral_outline.txt ; do
      if [ $i == 0 ]; then
        gmt plot $contour_dir/$lip $atrb -l"Flood\nBasalt\nProvinces"
      else
        gmt plot $contour_dir/$lip $atrb
      fi
      ((i++))
  done
}
