function DYKE(){
  gmt plot $folder/dikes/dikes_all_pessano2021.txt -W1p -l"Dykes"
  gmt plot $folder/dikes/dikes_camp_pessano2021.txt -W0.8p,green -l"Dykes CAMP"
  gmt plot $folder/dikes/dikes_equamp_pessano2021.txt -W0.8p,yellow -l"Dykes EQUAMP"
  gmt plot $folder/dikes/dikes_parana_pessano2021.txt -W0.8p,cyan -l"Dykes Paraná"
}
#------------------------------------------------------------------------------------------#
function MAG(){
  lipsel=$1
  maxage=$2
  sym=$3
  lin=$4
  echo $tag"~~overlay SA magmatism locations"
  if [ ${lipsel} == "overwrite" ]; then
    echo $tag$tag"~~overwrite locations inside LIPs"
    #select data points inside and around polygon with age dif from lip
    awk -v ma=$maxage '($3<ma) && ($3<100) || ($3>150) {print $1,$2,$3}' $folder/magmatism/igneous_rocks_all.txt \
      | gmt gmtselect -L$contour_dir/serra_geral_outline.txt+d50k -fg > in_pol.txt
    awk -v ma=$maxage '($3<ma) && ($3<100) || ($3>150) {print $1,$2,$3}' $folder/magmatism/igneous_rocks_all.txt \
      | gmt gmtselect -F$contour_dir/serra_geral_outline.txt -fg >> in_pol.txt
    awk -v ma=$maxage '($3<ma) && ($3<150) || ($3>350) {print $1,$2,$3}' $folder/magmatism/igneous_rocks_all.txt \
      | gmt gmtselect -L$contour_dir/camp_outline.txt+d50k -fg >> in_pol.txt
    awk -v ma=$maxage '($3<ma) && ($3<150) || ($3>350) {print $1,$2,$3}' $folder/magmatism/igneous_rocks_all.txt \
      | gmt gmtselect -F$contour_dir/camp_outline.txt -fg >> in_pol.txt
    gmt plot in_pol.txt $sym -W0.4p -Cages.cpt.$tmp
    #select all data points outside the LIP polygons and 10km around
    awk  -v ma=$maxage '($3<ma) && ($3!=0) {print $1,$2,$3}' $folder/magmatism/igneous_rocks_all.txt \
      | gmt gmtselect -F$contour_dir/camp_outline.txt -If -fg \
      | gmt gmtselect -L$contour_dir/camp_outline.txt+d10k -Il -fg \
      | gmt gmtselect -L$contour_dir/serra_geral_outline.txt+d10k -Il -fg \
      | gmt gmtselect -F$contour_dir/serra_geral_outline.txt -If -fg \
      | gmt plot $sym -W0.4p -Cages.cpt.$tmp
  elif [ ${lipsel} == "yes" ]; then
    echo $tag$tag"~~plot select mag locations outside LIPs"
    #awk  -v ma=$maxage '($3<ma) && ($3!=0) {print $1,$2,$3}' $folder/magmatism/igneous_rocks_all.txt | \
    #  gmt plot -fg -St5p -W0.4p -Gblack
    gmt plot in_pol.txt $sym -W0.4p -Cages.cpt.$tmp
    #select all data points outside the LIP polygons and 10km around
    awk  -v ma=$maxage '($3<ma) && ($3!=0) {print $1,$2,$3}' $folder/magmatism/igneous_rocks_all.txt \
      |  gmt gmtselect -F$contour_dir/camp_outline.txt -If -fg \
      |  gmt gmtselect -L$contour_dir/camp_outline.txt+d10k -Il -fg \
      | gmt gmtselect -L$contour_dir/serra_geral_outline.txt+d10k -Il -fg \
      | gmt gmtselect -F$contour_dir/serra_geral_outline.txt -If -fg \
      | gmt plot $sym -W0.4p -Cages.cpt.$tmp
  else
    awk -v ma=$maxage '($3<ma) && ($3!=0) {print $1,$2,$3}' $folder/magmatism/igneous_rocks_all.txt \
      | gmt plot $sym -W0.4p -fg -Cages.cpt.$tmp
  fi
  #gmt psscale -DjTR+w4/0.2c+h -Cages.cpt.$tmp -F+gwhite+p -Bx50+l"Ages [Ma]"
}
#------------------------------------------------------------------------------------------#
function HOT(){
  model=$1
  modname=$2
  line=$3
  echo $tag"~~overlay hotspots and hotspot tracks"
  ii=-1
  minage=200
  for tr in $model; do
    ((ii++))
    awk -v ma=$minage -v count=$ii '($3<ma) {print $1,$2}' $tr | gmt plot -W$line",.."
    awk -v ma=$minage -v count=$ii '($3<ma) {print $1,$2, $3}' $tr | gmt plot -Sc0.1 -Cages.cpt.$tmp -W0.1p
  done
  minage=130
  for tr in $model; do
    ((ii++))
    awk -v ma=$minage -v count=$ii '($3<ma) {print $1,$2}' $tr | gmt plot -W$line -l"$modname"
    awk -v ma=$minage -v count=$ii '($3<ma) {print $1,$2, $3}' $tr | gmt plot -Sc0.1 -Cages.cpt.$tmp -W0.1p
  done
}
#------------------------------------------------------------------------------------------#
function HOTSPOTS(){
  gmt plot -Sd0.4 -W0.7p -Gyellow $folder/hotspots/hotspots_whittaker2015.xy -l"Hotspots"
  #echo "-27.7806 5.3337" | gmt plot -Sd0.2 -W0.7p -Gyellow
}
#------------------------------------------------------------------------------------------#
function TRISTAN(){
  model=$1
  echo $tag"~~overlay hotspots and hotspot tracks"
  ii=-1
  minage=200
  maxage=0
  echo "-14.4201 -34.5095" | gmt plot -Sd0.4 -W0.7p -Gmagenta
  for tr in $model; do
    ((ii++))
    awk -v mi=$minage -v ma=$maxage -v count=$ii '($3<mi) && ($3>ma) {print $1,$2}' $tr | gmt plot -W1.5p,black
    awk -v ma=$minage -v count=$ii '($3<ma) {print $1,$2}' $tr | gmt plot -W1p,magenta
    awk -v ma=$minage -v count=$ii '($3<ma) {print $1,$2, $3}' $tr | gmt plot -Sc0.1 -Cages.cpt.$tmp -W0.1p
  done
  minage=130
  maxage=0
  for tr in $model; do
    ((ii++))
    awk -v mi=$minage -v ma=$maxage -v count=$ii '($3<mi) && ($3>ma) {print $1,$2}' $tr | gmt plot -W1.5p,black
    awk -v mi=$minage -v ma=$maxage -v count=$ii '($3<mi) && ($3>ma) {print $1,$2}' $tr | gmt plot -W0.5p,magenta
    awk -v mi=$minage -v ma=$maxage -v count=$ii '($3<mi) && ($3>ma) {print $1,$2, $3}' $tr | gmt plot -Sc0.1 -Cages.cpt.$tmp -W0.1p
  done
}
#------------------------------------------------------------------------------------------#
function CRATON() {
  pen=$1
  fill=$2
  echo "    --Add cratons"

  #-- Inferred Craton Limits
  i=0
  for craton in $contour_dir/cratons/Sao_Luiz_Craton2.txt \
    $contour_dir/cratons/outer_layer.txt $contour_dir/cratons/SFC_bru.gmt \
    $contour_dir/cratons/Luiz_Alves_Craton.txt  \
    $contour_dir/cratons/Sao_Luiz_Craton.txt $contour_dir/cratons/Sao_Luiz_Craton2.txt; do
    
    if [ $fill == "empty" ]; then
      if [ $i == 0 ]; then
      gmt plot $craton -W${pen}
      else
      gmt plot $craton -W${pen}
      fi
    else
      if [ $i == 0 ]; then
        gmt plot $craton -W${pen} -G$fill
      else
        gmt plot $craton -W${pen} -G$fill
      fi
    fi
    ((i++))
  done
}

function INFCRATON() {
  pen=$1
  fill=$2
  echo "    --Add inferred cratons"

  #-- Inferred Craton Limits
  i=0
  for craton in $contour_dir/cratons/Parnaiba_block.txt \
    $contour_dir/cratons/Paranapanema.txt \
    $contour_dir/cratons/Rio_de_la_Plata_Craton.txt; do
    
  if [ $fill != "empty" ]; then
      if [ $i == 0 ]; then
      gmt plot $craton -W${pen} -G$fill
      else
      gmt plot $craton -W${pen} -G$fill
      fi
    else
      if [ $i == 0 ]; then
        gmt plot $craton -W${pen}
      else
        gmt plot $craton -W${pen}
      fi
    fi
    ((i++))
  done
}

