function PLOT_PLATES () {
  local pen=$1
  gmt plot -W${pen} ${plate}
}

function SV_TRACK () {

  local d=$1
  local data=$2
  local radius=$3
  local out=$4
  
  echo "$tag-svel/ $data  histogram"
  dvs=`echo dvsd$(echo ${d} | awk '{printf("%04d",$1)}')`
  awk '{if($3=="NaN") print $1,$2,$3; else print $1, $2, $3/$4*100}' ${sol}/${dvs} | gmt gmtselect $Rsel -fg > svel_select.$tmp

  gmt blockmean -I0.5 $Rsel $data | awk '{print $1, $2}' > data.bm.$tmp
  gmt gmtselect svel_select.$tmp -Cdata.bm.$tmp${radius} -fg > $out

}

#function PLOT_HIST () {
#}
function BASEMAP () {

  local base=$1
  local s=$2
  local d=$3
  local res=$4

  sol="$REPO_ROOT/data/seismic_model"
  echo "${tag}-- make basemap grd $base at ${d} km"

    case $base in
    topo)
      cpt=$scales/meyers.cpt
      #cpt=gray
      illu=""
      ingrd="@earth_relief_01m -I+a0"
      ;;
    svel)
      cpt=`gmt makecpt -T-${s}/${s}/0.05 -D -Z -C$tomocpt`
      #AVG_DVS $depth ${sol} m.out.$tmp ${s}
      dvs=`echo dvsd$(echo ${d} | awk '{printf("%04d",$1)}')`
      awk '{if($3=="NaN") print $1,$2,$3; else print $1, $2, $3/$4*100}' ${sol}/${dvs} |\
        gmt xyz2grd -I0.75 -Rg -Gm.${d}.grd.$tmp
      gmt grdsample m.$d.grd.$tmp -I${res} -Gm.out.$tmp
      ingrd=m.out.$tmp
      illu=""
      ;;
    contour)
      echo "$tag$tag --set contour"
      cpt=`gmt makecpt -D -Cgold,white,lightblue,cornflowerblue,blue,purple -T-10,-1,2,5.5,6.5,7.5,10`
      dvs=`echo dvsd$(echo ${d} | awk '{printf("%04d",$1)}')`
      awk '{if($3=="NaN") print $1,$2,$3; else print $1, $2, $3/$4*100}' ${sol}/${dvs} |\
        gmt xyz2grd -I0.75 -Rg -Gm.${d}.grd.$tmp
      gmt grdsample m.$d.grd.$tmp -I${res} -Gm.out.$tmp
      #gmt grdsample etopo_satlantic.grd -I${res} $Rres -Gillum.grd.$tmp -fig
      #illu="-Iillum.grd.$tmp"
      illu=""
      #ingrd=m.out.$tmp
      ;;
  esac
}

function AVG_DVS() {
  local dep=$1    #depth
  local pth=$2
  local grd=$3
  local s=$4    #saturation

  #loop over depths
  ii=0
  for d in ${dep}; do
    echo "${tag}--${ii}) calculate lithospheric average in ${d} km"
    #ref=`awk -v a=${d} '($1==a) {print $1,$2}' ${ref_path} | awk '{printf "%.2f", $2}'`
    dvs=`echo dvsd$(echo ${d} | awk '{printf("%04d",$1)}')`
    awk '{if($3=="NaN") print $1,$2,$3; else print $1, $2, $3/$4*100}' ${pth}/${dvs} | gmt xyz2grd -I0.75 -Rg -Gm.${d}.grd.$tmp

    if [ $ii -gt 0 ]; then
      gmt grdmath m.${d}.grd.$tmp m.grd.$tmp  ADD 2 DIV = m.grd.$tmp
     # refavg=$( echo "(${ref} + ${refavg})/2" | bc -l | awk '{printf "%.2f", $0}')
    else
      cp m.${d}.grd.$tmp m.grd.$tmp
      #refavg="${ref}"
    fi

    ii=$(( ii+1 ))
  done
gmt grdsample m.grd.$tmp -I${res} -G$grd
#gmt makecpt -T-${s}/${s}/0.01 -D -Z -C$tomocpt
}

